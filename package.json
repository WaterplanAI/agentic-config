{
  "name": "agentic-config-pi-root",
  "private": true,
  "version": "0.3.0-alpha",
  "description": "Umbrella pi package for agentic-config, alongside the repository's Claude Code plugin surface.",
  "license": "MIT",
  "homepage": "https://github.com/WaterplanAI/agentic-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/WaterplanAI/agentic-config.git",
    "directory": "."
  },
  "keywords": [
    "pi-package",
    "agentic-config",
    "pi",
    "git-install"
  ],
  "type": "module",
  "dependencies": {
    "@agentic-config/pi-compat": "file:packages/pi-compat",
    "@agentic-config/pi-ac-audit": "file:packages/pi-ac-audit",
    "@agentic-config/pi-ac-git": "file:packages/pi-ac-git",
    "@agentic-config/pi-ac-meta": "file:packages/pi-ac-meta",
    "@agentic-config/pi-ac-qa": "file:packages/pi-ac-qa",
    "@agentic-config/pi-ac-safety": "file:packages/pi-ac-safety",
    "@agentic-config/pi-ac-tools": "file:packages/pi-ac-tools",
    "@agentic-config/pi-ac-workflow": "file:packages/pi-ac-workflow"
  },
  "pi": {
    "skills": [
      "node_modules/@agentic-config/pi-ac-audit/skills",
      "node_modules/@agentic-config/pi-ac-git/skills",
      "node_modules/@agentic-config/pi-ac-meta/skills",
      "node_modules/@agentic-config/pi-ac-qa/skills",
      "node_modules/@agentic-config/pi-ac-safety/skills",
      "node_modules/@agentic-config/pi-ac-tools/skills",
      "node_modules/@agentic-config/pi-ac-workflow/skills"
    ],
    "extensions": [
      "node_modules/@agentic-config/pi-compat/extensions",
      "node_modules/@agentic-config/pi-ac-audit/extensions",
      "node_modules/@agentic-config/pi-ac-git/extensions",
      "node_modules/@agentic-config/pi-ac-meta/extensions",
      "node_modules/@agentic-config/pi-ac-qa/extensions",
      "node_modules/@agentic-config/pi-ac-safety/extensions",
      "node_modules/@agentic-config/pi-ac-tools/extensions",
      "node_modules/@agentic-config/pi-ac-workflow/extensions"
    ]
  }
}
